# ── Groq ──────────────────────────────────────────────────────────────────────
# Your Groq API key — never commit the real value
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Shared secret between backend and extension — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match CLIENT_SECRET in the extension's service-worker.js
CLIENT_SECRET=generate_a_64_char_hex_string_here

# Admin secret for /admin/* routes — only you use this
ADMIN_SECRET=generate_another_64_char_hex_string_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
