# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# CLIENT_SECRET: shared between the extension and backend to reject non-extension
# traffic. Hardcoded in background/service-worker.js — must match exactly.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_SECRET=generate_a_64_char_hex_string_here

# ADMIN_SECRET: protects the /admin/* API routes and the admin panel login.
# After 5 wrong attempts from one IP, that IP is locked out for 15 minutes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate_another_64_char_hex_string_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# APP_URL: your public-facing server URL. Not currently read by the Node app —
# used as a reference for Nginx config, DuckDNS setup, and LemonSqueezy webhook
# URL configuration. Keep it accurate so you have one source of truth.
APP_URL=https://YOUR_SUBDOMAIN.duckdns.org

# ── LemonSqueezy ───────────────────────────────────────────────────────────────
# Get these from your LemonSqueezy dashboard → Settings → Webhooks / Store / Products
#
# LEMONSQUEEZY_SIGNING_SECRET:
#   Dashboard → Settings → Webhooks → your webhook → Signing Secret
#   Used to verify HMAC-SHA256 signatures on incoming webhook events.
#
# LEMONSQUEEZY_VARIANT_ID:
#   Dashboard → Store → Products → JobSift Pro → Variants → copy the variant ID
#   Numeric ID only (e.g. 123456) — embedded in the checkout URL on /upgrade page.
#
# LEMONSQUEEZY_STORE_SUBDOMAIN:
#   Your store URL is https://SUBDOMAIN.lemonsqueezy.com
#   Just the subdomain part (e.g. 'jobsift' if your URL is jobsift.lemonsqueezy.com)

LEMONSQUEEZY_SIGNING_SECRET=your_webhook_signing_secret_here
LEMONSQUEEZY_VARIANT_ID=your_variant_id_here
LEMONSQUEEZY_STORE_SUBDOMAIN=your_store_subdomain_here

# ── Subscription behaviour ──────────────────────────────────────────────────────
# These are NOT environment variables — they are hardcoded constants in the
# backend source. Listed here for reference so you know where to change them.
#
# Trial period:    7 days  → src/db/database.ts: const TRIAL_DAYS = 7
# Free panel limit: 5/day → src/db/database.ts: const FREE_PANEL_LIMIT = 5
# Free parse limit: 3/day → src/middleware/rateLimit.ts: FREE_PROFILE_LIMIT = 3
# Pro parse limit: 20/day → src/middleware/rateLimit.ts: PRO_PROFILE_LIMIT = 20
# Log retention:   30 days → src/db/database.ts: const LOG_RETENTION_DAYS = 30
#
# The paywall on/off toggle is controlled live via the admin panel
# (/admin-panel → Subscriptions → Toggle paywall) without any restart needed.
