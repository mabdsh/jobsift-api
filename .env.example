# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_SECRET=generate_a_64_char_hex_string_here
ADMIN_SECRET=generate_another_64_char_hex_string_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://YOUR_SUBDOMAIN.duckdns.org

# ── LemonSqueezy ───────────────────────────────────────────────────────────────
# Get these from your LemonSqueezy dashboard → Settings → Webhooks / Store / Products
#
# LEMONSQUEEZY_SIGNING_SECRET:
#   Dashboard → Settings → Webhooks → your webhook → Signing Secret
#
# LEMONSQUEEZY_VARIANT_ID:
#   Dashboard → Store → Products → JobSift Pro → Variants → copy the variant ID
#   This is the numeric ID (e.g. 123456)
#
# LEMONSQUEEZY_STORE_SUBDOMAIN:
#   Your store URL is https://SUBDOMAIN.lemonsqueezy.com
#   Just the subdomain part (e.g. 'jobsift' if your URL is jobsift.lemonsqueezy.com)

LEMONSQUEEZY_SIGNING_SECRET=your_webhook_signing_secret_here
LEMONSQUEEZY_VARIANT_ID=your_variant_id_here
LEMONSQUEEZY_STORE_SUBDOMAIN=your_store_subdomain_here
